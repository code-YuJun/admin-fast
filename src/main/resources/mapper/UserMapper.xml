<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fast.springboot.mapper.UserMapper">
    <!--
        resultMap: 结果映射配置
        作用: 将数据库查询结果映射到Java对象
        type="com.fast.system.domain.User" 映射到User对象，
        因为在 application.yaml 中配置了 type-aliases-package: com.fast.**.domain 所以可以直接使用 User 类

        id="UserResult": 这个映射的唯一标识, 其他地方可以使用
    -->
    <resultMap id="UserResult" type="User">
        <!--
            id: 主键字段映射
            property="userId": Java对象中的属性名
            column="user_id": 数据库表中的列名
            作用: 告诉MyBatis, 数据库的user_id列对应Java对象中的userId属性
        -->
        <id property="userId" column="user_id"/>
        <!-- result: 普通字段映射每个<result>标签中的字段 -->
        <result property="userName" column="user_name"/>
        <result property="sex" column="sex"/>
        <result property="avatar" column="avatar"/>
        <result property="password" column="password"/>
        <result property="createTime" column="create_time"/>
    </resultMap>
    <!--
        select: 定义查询语句
        id="selectUserByUserName": 对应Mapper接口中的方法名
        resultMap="UserResult": 使用上面定义的resultMap进行结果映射
        parameterType="String": 参数类型（ 可以省略, Myabtis会自动判断 ）
    -->
    <select id="selectUserByUserName" parameterType="string" resultMap="UserResult">
        select user_id, user_name, sex, avatar, password, create_time
        from user
        where user_name = #{userName}
    </select>


    <select id="selectUserByUserId" parameterType="Long" resultMap="UserResult">
        select user_id, user_name, sex, avatar, password, create_time
        from user
        where user_id = #{userId}
    </select>

</mapper>